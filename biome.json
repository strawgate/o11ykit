{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/lib",
      "!**/coverage",
      "!**/node_modules",
      "!**/.site",
      "!**/playwright-report",
      "!**/test-results",
      "!**/target",
      "!octo11y",
      "!packages/o11ytsdb/bench",
      "!research"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "overrides": [
    {
      "includes": ["site/tsdb-engine/js/byte-explorer.js"],
      "linter": {
        "rules": {
          "correctness": {
            "noInnerDeclarations": "off"
          }
        }
      }
    }
  ]
}
