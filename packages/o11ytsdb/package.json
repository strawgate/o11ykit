{
  "name": "o11ytsdb",
  "version": "0.0.1",
  "description": "Browser-native time-series database for OpenTelemetry data.",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "opentelemetry",
    "otlp",
    "tsdb",
    "time-series",
    "metrics",
    "compression"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "wasm",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@otlpkit/otlpjson": "^0.2.3"
  },
  "scripts": {
    "build": "tsc -b",
    "build:rust": "cd rust && cargo build --release --target wasm32-unknown-unknown && cp target/wasm32-unknown-unknown/release/o11ytsdb_wasm.wasm ../wasm/o11ytsdb-rust.wasm",
    "build:wasm": "npm run build:rust",
    "build:all": "npm run build:wasm && npm run build",
    "bench:build": "tsc -p bench/tsconfig.json",
    "bench:prepare": "npm run build:all && npm run bench:build",
    "bench": "npm run bench:prepare && node bench/run.mjs",
    "bench:codec": "npm run bench -- codec",
    "bench:interner": "npm run bench -- interner",
    "bench:postings": "npm run bench -- postings",
    "bench:ingest": "npm run bench -- ingest",
    "bench:query": "npm run bench -- query",
    "bench:rowgroup-layout": "npm run bench:prepare && node --expose-gc dist-bench/rowgroup-layout.bench.js",
    "bench:chunk-size-sweep": "npm run bench:prepare && node dist-bench/chunk-size-sweep.js",
    "bench:compaction": "npm run bench:prepare && node dist-bench/compaction.js",
    "bench:memory-curve": "npm run bench:prepare && node dist-bench/memory-curve.js",
    "bench:rowgroup-memory-audit": "npm run bench:prepare && node dist-bench/rowgroup-memory-audit.js",
    "bench:rowgroup-profile": "npm run bench:prepare && node --expose-gc dist-bench/rowgroup-profile.js",
    "bench:tiered-cardinality-sweep": "npm run bench:prepare && node dist-bench/tiered-cardinality-sweep.js",
    "bench:tiered-store-matrix": "npm run bench:prepare && node dist-bench/tiered-store-matrix.js",
    "bench:tiered-rowgroup": "npm run bench:prepare && node dist-bench/tiered-rowgroup-compare.js",
    "bench:tiered-query-matrix": "npm run bench:prepare && node dist-bench/tiered-query-matrix.js",
    "bench:compare": "npm run bench -- --compare",
    "smoke": "npm run build && node bench/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
