                    "count": "4",
                    "sum": 53,
                    "bucketCounts": ["1", "2", "1"],
                    "explicitBounds": [10, 50]
                  }
                ]
              }
            },
            {
              "name": "rpc.latency",
              "summary": {
                "dataPoints": [
                  {
                    "timeUnixNano": "1710000001000000000",
