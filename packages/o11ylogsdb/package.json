{
  "name": "o11ylogsdb",
  "version": "0.0.0",
  "description": "Browser-native logs database for OpenTelemetry data.",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "opentelemetry",
    "otlp",
    "logs",
    "compression",
    "browser"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "wasm",
    "README.md",
    "PLAN.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "build:rust": "cd rust && cargo build --release --target wasm32-unknown-unknown && cp target/wasm32-unknown-unknown/release/o11ylogsdb_wasm.wasm ../wasm/o11ylogsdb-rust.wasm",
    "build:wasm": "npm run build:rust",
    "build:all": "npm run build:wasm && npm run build",
    "bench:fetch": "bash bench/scripts/download-loghub.sh",
    "bench:drain-fixtures": "python3 bench/scripts/generate-drain-fixtures.py",
    "bench:build": "tsc -p bench/tsconfig.json",
    "bench:prepare": "npm run bench:fetch && npm run bench:drain-fixtures && npm run bench:build",
    "bench": "npm run bench:prepare && node bench/run.mjs",
    "bench:markdown": "npm run bench:prepare && node bench/run.mjs --markdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
